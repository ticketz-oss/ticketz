# O Nginx do frontend container faz proxy de /backend/ → backend:3000 internamente
# O browser acessa tudo pelo mesmo dominio note.lpvoicetecnologia.com.br
# REACT_APP_BACKEND_URL tem prioridade no config.js (evita adicionar :443 na URL)
REACT_APP_BACKEND_URL=https://note.lpvoicetecnologia.com.br/backend
FRONTEND_URL=https://note.lpvoicetecnologia.com.br
BACKEND_URL=https://note.lpvoicetecnologia.com.br/backend
BACKEND_HOST=note.lpvoicetecnologia.com.br
BACKEND_PROTOCOL=https
BACKEND_PORT=443
BACKEND_PATH=/backend
