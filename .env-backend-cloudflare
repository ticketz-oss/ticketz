# note.lpvoicetecnologia.com.br  → frontend:80 (Cloudflare tunnel)
# note1.lpvoicetecnologia.com.br → backend:3000 (Cloudflare tunnel)

TZ=America/Sao_Paulo

# URL que o backend usa para gerar links de webhook (ex: Telegram, Meta)
BACKEND_URL=https://note1.lpvoicetecnologia.com.br
FRONTEND_URL=https://note.lpvoicetecnologia.com.br

## normalmente não precisa editar daqui em diante

DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=ticketz
DB_NAME=ticketz
DB_TIMEZONE=-03:00

REDIS_URI=redis://redis:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

# ─── Meta / Facebook ─────────────────────────────
# Obtenha em https://developers.facebook.com > Seu App > Configurações > Básico
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# DEVE ser EXATAMENTE o mesmo token que você colocou no Facebook Developers
# em Webhooks > Editar assinatura > Token de verificação
VERIFY_TOKEN=Aa123456

# Webhook URL para WhatsApp Cloud API e Instagram (no Facebook Developers):
# https://note.lpvoicetecnologia.com.br/backend/webhook/meta

# ─── Telegram ────────────────────────────────────
# Webhook URL para Telegram (configure via BotFather):
# https://note1.lpvoicetecnologia.com.br/backend/webhook/telegram/SEU_TOKEN_DO_BOT

# ─── E-mail / SMTP+IMAP ──────────────────────────
# Configurado por conexão no painel (SMTP + IMAP)

SOCKET_ADMIN=true
