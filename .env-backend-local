# ================================================================
#  Solution Zap - Configuração do Backend (ambiente local/dev)
#  Copie este arquivo para .env-backend-local e ajuste os valores
# ================================================================

# ----- URLs -----
FRONTEND_HOST=localhost
FRONTEND_PORT=3000
BACKEND_PATH=/backend
BACKEND_URL=http://${FRONTEND_HOST}:${FRONTEND_PORT}${BACKEND_PATH}
FRONTEND_URL=http://${FRONTEND_HOST}:${FRONTEND_PORT}

# ----- Admin padrão (usado no primeiro seed) -----
EMAIL_ADDRESS=admin@solutionzap.com.br
ADMIN_PASSWORD=SolutionZap@2025

# ----- Fuso horário -----
TZ=America/Sao_Paulo

# ----- Banco de dados -----
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=solutionzap
DB_NAME=solutionzap
DB_TIMEZONE=-03:00

# ----- Redis -----
REDIS_URI=redis://redis:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

# ----- Limites -----
USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

# ----- Facebook / Instagram (opcional) -----
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ----- Tokens internos -----
VERIFY_TOKEN=solutionzap_verify
SOCKET_ADMIN=false

# ----- JWT (TROQUE em produção!) -----
JWT_SECRET=SolutionZap_JWT_Secret_Troque_Em_Producao
JWT_REFRESH_SECRET=SolutionZap_JWT_Refresh_Troque_Em_Producao
